{
  "name": "dat-phong-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create dat-phong-db",
    "db:migrate": "wrangler d1 execute dat-phong-db --file=./schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute dat-phong-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.8.0",
    "wrangler": "^3.99.0"
  },
  "dependencies": {
    "@pushforge/builder": "^2.0.2"
  }
}
